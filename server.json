{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.wkoverfield/quilt",
  "description": "Track which AI agent wrote which lines in a shared Git checkout; each commits only its own lines.",
  "version": "0.5.1",
  "repository": {
    "url": "https://github.com/wkoverfield/quilt",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@quilt-dev/cli",
      "version": "0.5.1",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp"
        }
      ]
    }
  ]
}
