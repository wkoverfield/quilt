{
  "name": "quilt-cli",
  "version": "0.0.1",
  "description": "Actor-owned patches for Git. Same repo. Many agents. Clean commits.",
  "type": "module",
  "bin": {
    "quilt": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "author": "Wilson Overfield",
  "homepage": "https://github.com/woverfield/quilt#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/woverfield/quilt.git"
  },
  "bugs": {
    "url": "https://github.com/woverfield/quilt/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "npm run build && node --import tsx --test test/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "git",
    "agents",
    "patch",
    "attribution",
    "ownership",
    "ai",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
