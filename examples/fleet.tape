# The ceiling demo GIF: 7 agents on one repo, plain git vs Quilt.
#   vhs examples/fleet.tape        # writes examples/fleet.gif  (run from repo root)
# Keep dist/ built first: npm run build.

Output examples/fleet.gif

Set Shell bash
Set Width 1000
Set Height 760
Set FontSize 13
Set Padding 24
Set TypingSpeed 35ms

Type "./examples/fleet.sh"
Enter
Sleep 17s
Sleep 2s
